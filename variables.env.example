# Discord Bot Credentials
DISCORD_TOKEN=your_discord_bot_token_here

# LLM Provider Configuration
# Choose from: openrouter | ollama | huggingface | google
LLM_PROVIDER=google

# 1. OpenRouter Configuration (Recommended for Gemma 4 31B)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemma-4-31b-it

# 2. Ollama Configuration (For running Gemma 4 or other models locally)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b

# 3. Hugging Face Configuration (Free Hugging Face Serverless API)
HUGGINGFACE_API_TOKEN=your_huggingface_api_token_here
HUGGINGFACE_MODEL=google/gemma-2-27b-it

# 4. Google AI Studio Configuration (For using Gemma/Gemini models directly)
GEMINI_API_KEY=your_google_ai_studio_api_key_here
GEMINI_MODEL=gemma-4-31b-it

# Bot Settings
BUMP_INTERVAL_MINUTES=120
DATABASE_PATH=lulu_bot.db

# Optional: List of channels (comma separated) where the bot will respond to conversation.
# If left empty, the bot responds to mentions and DMs in all channels.
ALLOWED_CHANNEL_IDS=
